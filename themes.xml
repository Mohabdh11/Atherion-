<?xml version="1.0" encoding="utf-8"?>
<!--
    Aetherion Mobile NOC — App Theme
    Developer: Mohammad Abdalftah Ibrahime
-->
<resources>
    <!-- Base application theme — dark by default -->
    <style name="Theme.AetherionNOC" parent="android:Theme.Material.NoTitleBar">
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:navigationBarColor">@color/surface_card</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.AetherionNOC.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AetherionNOC</item>
    </style>
</resources>
